  "providers": {
    "editor": "textarea-adapter-now-codemirror-ready",
    "compiler": "backend-texlive-real-runner | browser-wasm-placeholder | mock-draft",
    "ai": "backend-provider-proxy + structured-workflow-context",
    "patchReview": "json-patch-preview-before-apply",
    "sync": "local-only | http-project | websocket-placeholder",
    "preview": "draft-html | pdf-blob"
  },
  "copilotWorkflows": [
    "fix-error-patch",
    "explain-log",
    "rewrite-selection-patch",
    "insert-section-patch",
    "beamer-outline-patch",
    "table-helper-patch",
    "raw-advice"
  ],
  "backendSecurity": {
    "workspace": "temporary isolated directory per compile",
    "cleanup": "enabled by default",
    "shellEscape": "disabled unless ALLOW_SHELL_ESCAPE=true",
    "providerSecrets": "backend environment only",
    "limits": ["MAX_PROJECT_BYTES", "MAX_PROJECT_FILES", "COMPILE_TIMEOUT_MS", "MAX_PDF_BYTES", "MAX_COMPILE_LOG_BYTES"],
    "rateLimits": ["COMPILE_RATE_LIMIT_PER_MINUTE", "RATE_LIMIT_PER_MINUTE"]
  }

    "websocket": {
      "reservedPath": "/ws/lumina/projects/:projectId",
      "messageTypes": ["presence", "file-patch", "compile-progress", "comment", "ai-stream", "project-notice"],
      "status": "reserved-for-stage2-collaboration"
